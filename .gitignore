# 排除 Node.js 套件目錄（這個極大，絕對不要傳）
node_modules/

# 排除 TypeScript 編譯後的 JavaScript 產物
dist/

# 排除臨時編譯的工作目錄
workspace_*/

# ⚠️ 排除你的自簽憑證隱私檔案（保護安全性）
server.key
server.crt

# 排除系統暫存檔
.DS_Store
Thumbs.db

# 排除 Arduino 隔離的設定與資料檔
.arduino-data/
bin/
tmp_workspace/
tmp_test_data/

# 排除 Electron 打包產物
release/

# 排除日誌與除錯檔案
*.log
npm-debug.log*

# 排除環境變數與金鑰檔案
.env
.env.local

# 排除編輯器設定
.vscode/
.idea/