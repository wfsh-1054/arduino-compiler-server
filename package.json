{
  "name": "maker-ide",
  "version": "1.1.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "postinstall": "npm run setup && cd frontend && npm install",
    "setup": "node scripts/setup.js",
    "dev:backend": "ts-node src/server.ts",
    "dev:frontend": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:backend": "tsc",
    "build:frontend": "cd frontend && npm run build",
    "build": "npm run build:frontend && npm run build:backend",
    "start:desktop": "npm run build && electron .",
    "pack:desktop": "npm run build && electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1",
    "cert": "node scripts/cert.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.0",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.makeride.app",
    "productName": "Maker IDE",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "dist/**/*",
      "frontend/dist/**/*",
      "bin/**/*",
      "scripts/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      "server.key",
      "server.crt"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "signExecutable": false
    },
    "asarUnpack": [
      "bin/**/*"
    ]
  }
}
